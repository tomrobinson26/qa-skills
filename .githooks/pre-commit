#!/bin/bash
# Pre-commit hook:
#   1. Auto-bump patch version in SKILL.md files staged for commit.
#   2. Regenerate .claude-plugin/marketplace.json from SKILL.md frontmatter.
#
# Install once with:
#   git config core.hooksPath .githooks

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ---------------------------------------------------------------------------
# 1. Version bump for any staged SKILL.md files
# ---------------------------------------------------------------------------

changed=$(git diff --cached --name-only | grep -E '^skills/[^/]+/SKILL\.md$')

if [ -n "$changed" ]; then
  while IFS= read -r skill_file; do
    [ -f "$skill_file" ] || continue

    current=$(grep -m1 '  version:' "$skill_file" | sed 's/.*version: "\(.*\)".*/\1/')
    [ -z "$current" ] && continue

    major=$(echo "$current" | cut -d. -f1)
    minor=$(echo "$current" | cut -d. -f2)
    patch=$(echo "$current" | cut -d. -f3)

    if [ -n "$patch" ]; then
      new_version="${major}.${minor}.$((patch + 1))"
    else
      new_version="${major}.$((minor + 1))"
    fi

    perl -i -pe "s|(  version: \")${current}(\")|\${1}${new_version}\${2}|" "$skill_file"
    git add "$skill_file"
    echo "  skill version bump: $skill_file  $current -> $new_version"
  done <<< "$changed"
fi

# ---------------------------------------------------------------------------
# 2. Regenerate marketplace.json
# ---------------------------------------------------------------------------

if ! bash "$REPO_ROOT/scripts/generate-marketplace.sh"; then
  echo "ERROR: generate-marketplace.sh failed. Commit aborted." >&2
  exit 1
fi

# Stage marketplace.json if the script changed it
if ! git diff --quiet ".claude-plugin/marketplace.json" 2>/dev/null; then
  git add ".claude-plugin/marketplace.json"
  echo "  staged updated .claude-plugin/marketplace.json"
fi

exit 0
